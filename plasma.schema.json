{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MPIEMSES3D plasma.toml",
  "description": "JSON Schema for MPIEMSES3D TOML input. Top-level groups are strict; individual groups allow additional properties so the schema can be extended incrementally.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional editor schema hint. Ignored by MPIEMSES3D."
    },
    "meta": {
      "$ref": "#/$defs/meta_group",
      "description": "Unit conversion metadata (not read by the Fortran solver)."
    },
    "real": {
      "$ref": "#/$defs/real_group",
      "description": "Physical constants used by the preprocessor (preinp)."
    },
    "realcv": {
      "$ref": "#/$defs/realcv_group",
      "description": "Derived conversion values used by the preprocessor (preinp)."
    },
    "esorem": {
      "$ref": "#/$defs/esorem_group",
      "description": "Field solver mode selection."
    },
    "jobcon": {
      "$ref": "#/$defs/jobcon_group",
      "description": "Job execution control."
    },
    "digcon": {
      "$ref": "#/$defs/digcon_group",
      "description": "Diagnostic and output control."
    },
    "plasma": {
      "$ref": "#/$defs/plasma_group",
      "description": "Plasma species and field parameters."
    },
    "tmgrid": {
      "$ref": "#/$defs/tmgrid_group",
      "description": "Time and spatial grid definition."
    },
    "system": {
      "$ref": "#/$defs/system_group",
      "description": "System-wide control flags and boundary conditions."
    },
    "intp": {
      "$ref": "#/$defs/intp_group",
      "description": "Particle integration and initialization."
    },
    "others": {
      "$ref": "#/$defs/others_group",
      "description": "Miscellaneous parameters."
    },
    "inp": {
      "$ref": "#/$defs/inp_group",
      "description": "Particle injection at domain boundaries."
    },
    "ptcond": {
      "$ref": "#/$defs/ptcond_group",
      "description": "Surface and conductor boundary settings."
    },
    "wave": {
      "$ref": "#/$defs/wave_group",
      "description": "Wave excitation parameters."
    },
    "scrnt": {
      "$ref": "#/$defs/scrnt_group",
      "description": "Screen current diagnostics."
    },
    "jsrc": {
      "$ref": "#/$defs/jsrc_group",
      "description": "Local oscillating current sources."
    },
    "testch": {
      "$ref": "#/$defs/testch_group",
      "description": "Static test charges."
    },
    "dipole": {
      "$ref": "#/$defs/dipole_group",
      "description": "Embedded magnetic dipole sources."
    },
    "emissn": {
      "$ref": "#/$defs/emissn_group",
      "description": "Particle emission from surfaces."
    },
    "mpi": {
      "$ref": "#/$defs/mpi_group",
      "description": "MPI domain decomposition."
    },
    "verbose": {
      "$ref": "#/$defs/verbose_group",
      "description": "Verbosity and debug control."
    },
    "gradema": {
      "$ref": "#/$defs/gradema_group",
      "description": "Surface charging acceleration control."
    }
  },
  "$defs": {
    "int": {
      "type": "integer"
    },
    "num": {
      "type": "number"
    },
    "bool": {
      "type": "boolean"
    },
    "str": {
      "type": "string"
    },
    "int_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/int"
      }
    },
    "num_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/num"
      }
    },
    "bool_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bool"
      }
    },
    "str_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/str"
      }
    },
    "int_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/int_array"
      }
    },
    "num_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/num_array"
      }
    },
    "num_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/num"
        },
        {
          "$ref": "#/$defs/num_array"
        },
        {
          "$ref": "#/$defs/num_matrix"
        }
      ]
    },
    "int_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/int"
        },
        {
          "$ref": "#/$defs/int_array"
        },
        {
          "$ref": "#/$defs/int_matrix"
        }
      ]
    },
    "bool_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/bool"
        },
        {
          "$ref": "#/$defs/bool_array"
        }
      ]
    },
    "str_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/str"
        },
        {
          "$ref": "#/$defs/str_array"
        }
      ]
    },
    "meta_group": {
      "type": "object",
      "description": "Unit conversion metadata. Not consumed by the solver; preserved for post-processing and visualization.",
      "additionalProperties": false,
      "properties": {
        "unit_conversion": {
          "type": "object",
          "description": "Normalization keys that map simulation units to physical units.",
          "additionalProperties": false,
          "properties": {
            "dx": {
              "description": "Grid spacing in physical units [m]. Corresponds to !!key dx=[…] in plasma.inp.",
              "oneOf": [
                {
                  "$ref": "#/$defs/num"
                },
                {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 1,
                  "items": {
                    "$ref": "#/$defs/num"
                  }
                }
              ]
            },
            "to_c": {
              "description": "Ratio of physical light speed to normalized light speed (cv): to_c = c_phys / cv.",
              "oneOf": [
                {
                  "$ref": "#/$defs/num"
                },
                {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 1,
                  "items": {
                    "$ref": "#/$defs/num"
                  }
                }
              ]
            }
          }
        }
      }
    },
    "real_group": {
      "type": "object",
      "description": "Physical constants for the preprocessor (preinp). Values here are not read by the solver directly.",
      "additionalProperties": true,
      "properties": {
        "deltax": {
          "type": "number",
          "description": "Grid spacing [m]."
        },
        "deltat": {
          "type": "number",
          "description": "Time step [s]."
        },
        "massratio": {
          "type": "number",
          "description": "Ion-to-electron mass ratio."
        },
        "density": {
          "type": "number",
          "description": "Plasma number density [m^-3]."
        },
        "etemp": {
          "type": "number",
          "description": "Electron temperature [eV]."
        },
        "itemp": {
          "type": "number",
          "description": "Ion temperature [eV]."
        },
        "phtemp": {
          "type": "number",
          "description": "Photoelectron temperature [eV]."
        },
        "flowvx": {
          "type": "number",
          "description": "Bulk flow velocity x-component [m/s]."
        },
        "flowvy": {
          "type": "number",
          "description": "Bulk flow velocity y-component [m/s]."
        },
        "flowvz": {
          "type": "number",
          "description": "Bulk flow velocity z-component [m/s]."
        },
        "magb": {
          "type": "number",
          "description": "Background magnetic field magnitude [T]."
        },
        "jph": {
          "type": "number",
          "description": "Photoemission current density [A/m^2]."
        }
      }
    },
    "realcv_group": {
      "type": "object",
      "description": "Derived conversion values for the preprocessor.",
      "additionalProperties": true,
      "properties": {
        "cvsim": {
          "type": "number",
          "description": "Normalized light speed used in the simulation."
        },
        "weightph": {
          "type": "number",
          "description": "Photoelectron statistical weight."
        }
      }
    },
    "esorem_group": {
      "type": "object",
      "description": "Electromagnetic/electrostatic solver mode.",
      "additionalProperties": true,
      "properties": {
        "emflag": {
          "type": "integer",
          "enum": [
            0,
            1,
            2
          ],
          "description": "Field solver mode. 0 = Electrostatic (Poisson), 1 = Full electromagnetic (Maxwell), 2 = CoToCoA."
        },
        "nflag_testp": {
          "type": "integer",
          "description": "Test particle flag."
        }
      }
    },
    "jobcon_group": {
      "type": "object",
      "description": "Job execution control: restart, snapshot, and step count.",
      "additionalProperties": true,
      "properties": {
        "jobnum": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "[restart_flag, snapshot_flag]. restart_flag: 0=new, 1=restart from SNAPSHOT0. snapshot_flag: 0=no output, 1=save to SNAPSHOT1."
        },
        "nstep": {
          "type": "integer",
          "description": "Total number of time steps."
        },
        "lstep": {
          "type": "integer",
          "description": "Last step (alternative to nstep)."
        },
        "maxt": {
          "type": "integer",
          "description": "Maximum wall-clock time [s]."
        },
        "random_seed": {
          "type": "integer",
          "description": "Random number generator seed."
        }
      }
    },
    "digcon_group": {
      "type": "object",
      "description": "Diagnostic output frequency, range, and format for HDF5 dumps, field maps, and current density.",
      "additionalProperties": true,
      "properties": {
        "i1hdf": {
          "type": "integer",
          "description": "HDF5 output flag (axis 1)."
        },
        "i2hdf": {
          "type": "integer",
          "description": "HDF5 output flag (axis 2)."
        },
        "i3hdf": {
          "type": "integer",
          "description": "HDF5 output flag (axis 3)."
        },
        "hdfdigstart": {
          "type": "integer",
          "description": "Start time step for HDF5 diagnostic output."
        },
        "hdfdigend": {
          "type": "integer",
          "description": "End time step for HDF5 diagnostic output."
        },
        "ifdiag": {
          "type": "integer",
          "description": "Field diagnostic output interval [steps]."
        },
        "ijdiag": {
          "type": "integer",
          "description": "Current diagnostic output interval [steps]."
        },
        "iediag": {
          "type": "integer",
          "description": "Energy diagnostic interval [steps]. Negative excludes damping region."
        },
        "iddiag": {
          "type": "integer",
          "description": "Particle distribution diagnostic interval [steps]."
        },
        "isdiag": {
          "type": "integer",
          "description": "Sub-diagnostic interval [steps]. Negative disables output."
        },
        "iadiag": {
          "type": "integer",
          "description": "Additional diagnostic interval [steps]."
        },
        "intfoc": {
          "type": "integer",
          "description": "Main loop diagnostic interval (should be a multiple of mltstp). Default: 128."
        },
        "itchck": {
          "type": "integer",
          "description": "Checkpoint interval [steps]."
        },
        "daverg": {
          "type": "integer",
          "description": "Time-averaging window for diagnostics."
        },
        "ipahdf": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Per-species field data skip factor for HDF5 output."
        },
        "ipadig": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Per-species particle data skip factor."
        },
        "ipaxyz": {
          "$ref": "#/$defs/int_value",
          "description": "Particle data storage options: [x, y, z, vx, vy, vz, id] per species. 1=store, 0=skip."
        },
        "ifxyz": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Field data storage options: [ex, ey, ez, bx, by, bz, rho]. 1=store, 0=skip."
        },
        "ijxyz": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Current data storage: [ajx, ajy, ajz, phi]. 1=store, 0=skip."
        },
        "nvx": {
          "type": "integer",
          "description": "Velocity-space bins (x)."
        },
        "nvy": {
          "type": "integer",
          "description": "Velocity-space bins (y)."
        },
        "nvz": {
          "type": "integer",
          "description": "Velocity-space bins (z)."
        },
        "ikxmax": {
          "type": "integer",
          "description": "Maximum k-space index (x) for spectral diagnostics."
        },
        "ikymax": {
          "type": "integer",
          "description": "Maximum k-space index (y) for spectral diagnostics."
        },
        "ikzmax": {
          "type": "integer",
          "description": "Maximum k-space index (z) for spectral diagnostics."
        },
        "emarlxt": {
          "type": "integer",
          "description": "EMA relaxation time for diagnostics."
        }
      }
    },
    "plasma_group": {
      "type": "object",
      "description": "Fundamental plasma and field parameters in normalized EMSES units.",
      "additionalProperties": true,
      "properties": {
        "wp": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Plasma frequency per species. Indirectly sets plasma density: wp_s = sqrt(n_s q_s^2 / (eps0 m_s))."
        },
        "wc": {
          "type": "number",
          "description": "Electron cyclotron frequency. Sets background magnetic field strength: wc = e B0 / m_e."
        },
        "cv": {
          "type": "number",
          "description": "Normalized speed of light."
        },
        "gfactor": {
          "type": "number",
          "description": "Implicit solver factor (default: 0.5). Controls weighting between old/new time levels."
        },
        "phixy": {
          "type": "number",
          "description": "Azimuthal angle [deg] of the static magnetic field projected onto the x-y plane."
        },
        "phiz": {
          "type": "number",
          "description": "Elevation angle [deg] of the static magnetic field from the z-axis."
        },
        "e0x": {
          "type": "number",
          "description": "Static background electric field, x-component (default: 0.0)."
        },
        "e0y": {
          "type": "number",
          "description": "Static background electric field, y-component (default: 0.0)."
        },
        "e0z": {
          "type": "number",
          "description": "Static background electric field, z-component (default: 0.0)."
        },
        "rho0": {
          "type": "number",
          "description": "Reference charge density (default: -1.0 = auto). Positive value overrides the neutralizing background."
        },
        "denmod": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Density modulation amplitude per species."
        },
        "denk": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Density modulation wave number per species."
        },
        "omegalw": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Lower-hybrid frequency per species."
        }
      }
    },
    "tmgrid_group": {
      "type": "object",
      "description": "Time step and spatial resolution of the simulation domain.",
      "additionalProperties": true,
      "properties": {
        "dt": {
          "type": "number",
          "description": "Time step size. Must satisfy stability constraints (wp*dt < 1, wc*dt < 1, CFL for emflag=1)."
        },
        "dtf": {
          "type": "number",
          "description": "Field update time step (default: same as dt)."
        },
        "dr": {
          "type": "number",
          "description": "Grid spacing. Must be smaller than the local Debye length."
        },
        "nx": {
          "type": "integer",
          "description": "Number of grid cells in x."
        },
        "ny": {
          "type": "integer",
          "description": "Number of grid cells in y."
        },
        "nz": {
          "type": "integer",
          "description": "Number of grid cells in z."
        }
      }
    },
    "system_group": {
      "type": "object",
      "description": "System-wide control flags: species count, boundary conditions, and field masking.",
      "additionalProperties": true,
      "properties": {
        "nspec": {
          "type": "integer",
          "description": "Number of particle species (e.g. 1=electron, 2=ion, 3=photoelectron)."
        },
        "mltstp": {
          "type": "integer",
          "description": "Number of field update loops per particle push (multiple time step). Default: 1."
        },
        "mltstpf": {
          "type": "integer",
          "description": "Complementary field update multiplier (default: 1)."
        },
        "juncan": {
          "type": "integer",
          "description": "Current cancellation option. 0=none, 1=subtract uniform current, 2=no ES + subtract, -2=no ES only, >=1000=test particle mode."
        },
        "ionchg": {
          "type": "integer",
          "description": "Ion charging flag."
        },
        "nfbnd": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Field boundary condition per axis [x,y,z]. 0=periodic, 1=free, 2=damping."
        },
        "npbnd": {
          "$ref": "#/$defs/int_value",
          "description": "Particle boundary condition per axis and species. 0=periodic, 1=reflective, 2=free, -1=follow nfbnd."
        },
        "mtd_vbnd": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Potential boundary condition per axis [x,y,z]. 0=periodic, 1=Dirichlet, 2=Neumann, 3=open/free-space."
        },
        "boundary_conditions": {
          "$ref": "#/$defs/num_value",
          "description": "Boundary condition values."
        },
        "iphiref": {
          "$ref": "#/$defs/int_value",
          "description": "Potential reference point indices."
        },
        "imask": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Field component masking flags [B, E_trans, E_long, J, rho, …]. 1=enabled, 0=masked."
        },
        "separate_accumulated_and_space_charge": {
          "type": "boolean",
          "description": "If true, compute surface (accumulated) and space charge contributions separately (default: true)."
        }
      }
    },
    "intp_group": {
      "type": "object",
      "description": "Particle species attributes, initial placement, and integration parameters in normalized EMSES units.",
      "additionalProperties": true,
      "properties": {
        "np": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Particle buffer size per species. Increase if buffer overflow occurs during emission/injection."
        },
        "npin": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Initial macro-particle count per species at startup. Mutually exclusive with dnsf."
        },
        "qm": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Charge-to-mass ratio per species (electron = -1.0)."
        },
        "path": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Parallel thermal velocity per species (parallel to B0)."
        },
        "spa": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Parallel drift velocity in the distribution function (default: 0.0)."
        },
        "spe": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Perpendicular drift velocity per species (default: 0.0)."
        },
        "speth": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Direction angle of perpendicular drift [deg] (default: 0.0)."
        },
        "peth": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Perpendicular thermal velocity per species (perpendicular to B0)."
        },
        "f": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Loss-cone factor (default: 1.0). f=1 with peth=path gives isotropic. 0<f<1 gives loss-cone distribution."
        },
        "vdx": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Drift velocity x-component per species (Cartesian alternative to vdri/vdthz/vdthxy)."
        },
        "vdy": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Drift velocity y-component per species."
        },
        "vdz": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Drift velocity z-component per species."
        },
        "vpa": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Minimum of parallel velocity distribution range (default: -16.0)."
        },
        "vpb": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Maximum of parallel velocity distribution range (default: 16.0)."
        },
        "vpe": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Maximum of perpendicular velocity distribution range (default: 32.0)."
        },
        "nphi": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Number of azimuthal bins for velocity distribution diagnostics."
        },
        "ndst": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Distribution type per species."
        },
        "ioptd": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Particle placement optimization flag per species."
        },
        "vdri": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Bulk drift velocity magnitude per species."
        },
        "vdthz": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Drift direction zenith angle [deg] per species (0° = +z)."
        },
        "vdthxy": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Drift direction azimuthal angle [deg] per species (from +x, CCW)."
        },
        "lcgamma": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Loss-cone gamma parameter per species."
        },
        "lcbeta": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Loss-cone beta parameter per species."
        },
        "dnsf": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Particle density scaling factor. Sets how many physical particles are grouped into one macro-particle. Mutually exclusive with npin."
        }
      }
    },
    "others_group": {
      "type": "object",
      "description": "Miscellaneous parameters.",
      "additionalProperties": true,
      "properties": {
        "tcs": {
          "type": "number",
          "description": "Time constant parameter."
        },
        "cs": {
          "type": "number",
          "description": "Sound speed parameter."
        }
      }
    },
    "inp_group": {
      "type": "object",
      "description": "Particle injection from simulation domain boundaries.",
      "additionalProperties": true,
      "properties": {
        "inpf": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Injection flag at lower x-boundary per species. 0=no injection, 1=inject."
        },
        "inpb": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Injection flag at upper x-boundary per species. 0=no injection, 1=inject."
        },
        "injct": {
          "type": "array",
          "items": {
            "type": "integer"
          },
