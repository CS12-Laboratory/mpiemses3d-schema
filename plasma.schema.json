        "spa": { "$ref": "#/$defs/num_array" },
        "spe": { "$ref": "#/$defs/num_array" },
        "speth": { "$ref": "#/$defs/num_array" },
        "peth": { "$ref": "#/$defs/num_array" },
        "f": { "$ref": "#/$defs/num_array" },
        "vdx": { "$ref": "#/$defs/num_array" },
        "vdy": { "$ref": "#/$defs/num_array" },
        "vdz": { "$ref": "#/$defs/num_array" },
        "vpa": { "$ref": "#/$defs/num_array" },
        "vpb": { "$ref": "#/$defs/num_array" },
        "vpe": { "$ref": "#/$defs/num_array" },
        "nphi": { "$ref": "#/$defs/int_array" },
        "ndst": { "$ref": "#/$defs/int_array" },
        "ioptd": { "$ref": "#/$defs/int_array" },
        "vdri": { "$ref": "#/$defs/num_array" },
        "vdthz": { "$ref": "#/$defs/num_array" },
        "vdthxy": { "$ref": "#/$defs/num_array" },
        "lcgamma": { "$ref": "#/$defs/num_array" },
        "lcbeta": { "$ref": "#/$defs/num_array" },
        "dnsf": { "$ref": "#/$defs/int_array" }
      }
    },
    "others_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tcs": { "$ref": "#/$defs/num" },
        "cs": { "$ref": "#/$defs/num" }
      }
    },
    "inp_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "inpf": { "$ref": "#/$defs/int_array" },
        "inpb": { "$ref": "#/$defs/int_array" },
        "injct": { "$ref": "#/$defs/int_array" },
        "npr": { "$ref": "#/$defs/int_array" }
      }
    },
    "ptcond_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "boundary_type": { "$ref": "#/$defs/str" },
        "boundary_types": { "$ref": "#/$defs/str_array" },
        "zssurf": { "$ref": "#/$defs/num" },
        "zsbuf": { "$ref": "#/$defs/num" },
        "rcurv": { "$ref": "#/$defs/num" },
        "xlrechole": { "$ref": "#/$defs/num_array" },
        "xurechole": { "$ref": "#/$defs/num_array" },
        "ylrechole": { "$ref": "#/$defs/num_array" },
        "yurechole": { "$ref": "#/$defs/num_array" },
        "zlrechole": { "$ref": "#/$defs/num_array" },
        "zurechole": { "$ref": "#/$defs/num_array" },
        "rectangle_shape": { "$ref": "#/$defs/num_matrix" },
        "circle_origin": { "$ref": "#/$defs/num_matrix" },
        "circle_radius": { "$ref": "#/$defs/num_array" },
        "cuboid_shape": { "$ref": "#/$defs/num_matrix" },
        "sphere_origin": { "$ref": "#/$defs/num_matrix" },
        "sphere_radius": { "$ref": "#/$defs/num_array" },
        "cylinder_origin": { "$ref": "#/$defs/num_matrix" },
        "cylinder_radius": { "$ref": "#/$defs/num_array" },
        "cylinder_height": { "$ref": "#/$defs/num_array" },
        "disk_origin": { "$ref": "#/$defs/num_matrix" },
        "disk_height": { "$ref": "#/$defs/num_array" },
        "disk_radius": { "$ref": "#/$defs/num_array" },
        "disk_inner_radius": { "$ref": "#/$defs/num_array" },
        "npc": { "$ref": "#/$defs/int" },
        "npcg": { "$ref": "#/$defs/int" },
        "pcgs": { "$ref": "#/$defs/int_array" },
        "ccgs": { "$ref": "#/$defs/int_array" },
        "mtd_vchg": { "$ref": "#/$defs/int_array" },
        "modeww": { "$ref": "#/$defs/int" },
        "conductivity": { "$ref": "#/$defs/num_array" },
        "boundary_conductor_id": { "$ref": "#/$defs/int_array" },
        "max_bounce_count": { "$ref": "#/$defs/int_array" },
        "enable_secondary_electron_emission": { "$ref": "#/$defs/bool_array" },
        "boundary_se_model_type": { "$ref": "#/$defs/int_array" },
        "boundary_se_const_yield": { "$ref": "#/$defs/num_array" },
        "boundary_se_yield_max": { "$ref": "#/$defs/num_array" },
        "boundary_se_energy_max": { "$ref": "#/$defs/num_array" },
        "boundary_se_species_id": { "$ref": "#/$defs/int_array" }
      }
    },
    "wave_group": {
      "type": "object",
      "additionalProperties": true
    },
    "scrnt_group": {
      "type": "object",
      "additionalProperties": true
    },
    "jsrc_group": {
      "type": "object",
      "additionalProperties": true
