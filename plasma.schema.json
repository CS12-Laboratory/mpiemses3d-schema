        "dnsb": { "$ref": "#/$defs/int_array" },
        "imarea": { "$ref": "#/$defs/num_array" },
        "ipcpl": { "$ref": "#/$defs/int_array" },
        "nemd": { "$ref": "#/$defs/int_array" },
        "omniemit": { "$ref": "#/$defs/int" },
        "remf": { "$ref": "#/$defs/num_array" },
        "remb": { "$ref": "#/$defs/num_array" },
        "xmaxe": { "$ref": "#/$defs/num_array" },
        "xmine": { "$ref": "#/$defs/num_array" },
        "ymaxe": { "$ref": "#/$defs/num_array" },
        "ymine": { "$ref": "#/$defs/num_array" },
        "zmaxe": { "$ref": "#/$defs/num_array" },
        "zmine": { "$ref": "#/$defs/num_array" },
