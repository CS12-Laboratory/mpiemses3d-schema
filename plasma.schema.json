{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MPIEMSES3D plasma.toml",
  "description": "Initial JSON Schema for MPIEMSES3D TOML input. Top-level groups are strict; individual groups intentionally allow additional properties so the schema can be extended incrementally without blocking existing cases.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional editor schema hint. Ignored by MPIEMSES3D."
    },
    "meta": {
      "$ref": "#/$defs/meta_group"
    },
    "real": {
      "$ref": "#/$defs/real_group"
    },
    "realcv": {
      "$ref": "#/$defs/realcv_group"
    },
    "esorem": {
      "$ref": "#/$defs/esorem_group"
    },
    "jobcon": {
      "$ref": "#/$defs/jobcon_group"
    },
    "digcon": {
      "$ref": "#/$defs/digcon_group"
    },
    "plasma": {
      "$ref": "#/$defs/plasma_group"
    },
    "tmgrid": {
      "$ref": "#/$defs/tmgrid_group"
    },
    "system": {
      "$ref": "#/$defs/system_group"
    },
    "intp": {
      "$ref": "#/$defs/intp_group"
    },
    "others": {
      "$ref": "#/$defs/others_group"
    },
    "inp": {
      "$ref": "#/$defs/inp_group"
    },
    "ptcond": {
      "$ref": "#/$defs/ptcond_group"
    },
    "wave": {
      "$ref": "#/$defs/wave_group"
    },
    "scrnt": {
      "$ref": "#/$defs/scrnt_group"
    },
    "jsrc": {
      "$ref": "#/$defs/jsrc_group"
    },
    "testch": {
      "$ref": "#/$defs/testch_group"
    },
    "dipole": {
      "$ref": "#/$defs/dipole_group"
    },
    "emissn": {
      "$ref": "#/$defs/emissn_group"
    },
    "mpi": {
      "$ref": "#/$defs/mpi_group"
    },
    "verbose": {
      "$ref": "#/$defs/verbose_group"
    },
    "gradema": {
      "$ref": "#/$defs/gradema_group"
    }
  },
  "$defs": {
    "int": {
      "type": "integer"
    },
    "num": {
      "type": "number"
    },
    "bool": {
      "type": "boolean"
    },
    "str": {
      "type": "string"
    },
    "int_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/int"
      }
    },
    "num_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/num"
      }
    },
    "bool_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bool"
      }
    },
    "str_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/str"
      }
    },
    "int_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/int_array"
      }
    },
    "num_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/num_array"
      }
    },
    "num_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/num"
        },
        {
          "$ref": "#/$defs/num_array"
        },
        {
          "$ref": "#/$defs/num_matrix"
        }
      ]
    },
    "int_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/int"
        },
        {
          "$ref": "#/$defs/int_array"
        },
        {
          "$ref": "#/$defs/int_matrix"
        }
      ]
    },
    "bool_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/bool"
        },
        {
          "$ref": "#/$defs/bool_array"
        }
      ]
    },
    "str_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/str"
        },
        {
          "$ref": "#/$defs/str_array"
        }
      ]
    },
    "meta_group": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unit_conversion": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dx": {
              "oneOf": [
                {
                  "$ref": "#/$defs/num"
                },
                {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 1,
                  "items": {
                    "$ref": "#/$defs/num"
                  }
                }
              ]
            },
            "to_c": {
              "oneOf": [
                {
                  "$ref": "#/$defs/num"
                },
                {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 1,
                  "items": {
                    "$ref": "#/$defs/num"
                  }
                }
              ]
            }
          }
        }
      }
    },
    "real_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "deltax": { "$ref": "#/$defs/num" },
        "deltat": { "$ref": "#/$defs/num" },
        "massratio": { "$ref": "#/$defs/num" },
        "density": { "$ref": "#/$defs/num" },
        "etemp": { "$ref": "#/$defs/num" },
        "itemp": { "$ref": "#/$defs/num" },
        "phtemp": { "$ref": "#/$defs/num" },
        "flowvx": { "$ref": "#/$defs/num" },
        "flowvy": { "$ref": "#/$defs/num" },
        "flowvz": { "$ref": "#/$defs/num" },
        "magb": { "$ref": "#/$defs/num" },
        "jph": { "$ref": "#/$defs/num" }
      }
    },
    "realcv_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cvsim": { "$ref": "#/$defs/num" },
        "weightph": { "$ref": "#/$defs/num" }
      }
    },
    "esorem_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "emflag": {
          "type": "integer",
          "enum": [0, 1, 2]
        },
        "nflag_testp": { "$ref": "#/$defs/int" }
      }
    },
    "jobcon_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "jobnum": { "$ref": "#/$defs/int_array" },
        "nstep": { "$ref": "#/$defs/int" },
        "lstep": { "$ref": "#/$defs/int" },
        "maxt": { "$ref": "#/$defs/int" },
        "random_seed": { "$ref": "#/$defs/int" }
      }
    },
    "digcon_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "i1hdf": { "$ref": "#/$defs/int" },
        "i2hdf": { "$ref": "#/$defs/int" },
        "i3hdf": { "$ref": "#/$defs/int" },
        "hdfdigstart": { "$ref": "#/$defs/int" },
        "hdfdigend": { "$ref": "#/$defs/int" },
        "ifdiag": { "$ref": "#/$defs/int" },
        "ijdiag": { "$ref": "#/$defs/int" },
        "iediag": { "$ref": "#/$defs/int" },
        "iddiag": { "$ref": "#/$defs/int" },
        "isdiag": { "$ref": "#/$defs/int" },
        "iadiag": { "$ref": "#/$defs/int" },
        "intfoc": { "$ref": "#/$defs/int" },
        "itchck": { "$ref": "#/$defs/int" },
        "daverg": { "$ref": "#/$defs/int" },
        "ipahdf": { "$ref": "#/$defs/int_array" },
        "ipadig": { "$ref": "#/$defs/int_array" },
        "ipaxyz": { "$ref": "#/$defs/int_value" },
        "ifxyz": { "$ref": "#/$defs/int_array" },
        "ijxyz": { "$ref": "#/$defs/int_array" },
        "nvx": { "$ref": "#/$defs/int" },
        "nvy": { "$ref": "#/$defs/int" },
        "nvz": { "$ref": "#/$defs/int" },
        "ikxmax": { "$ref": "#/$defs/int" },
        "ikymax": { "$ref": "#/$defs/int" },
        "ikzmax": { "$ref": "#/$defs/int" },
        "emarlxt": { "$ref": "#/$defs/int" }
      }
    },
    "plasma_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "wp": { "$ref": "#/$defs/num_array" },
        "wc": { "$ref": "#/$defs/num" },
        "cv": { "$ref": "#/$defs/num" },
        "gfactor": { "$ref": "#/$defs/num" },
        "phixy": { "$ref": "#/$defs/num" },
        "phiz": { "$ref": "#/$defs/num" },
        "e0x": { "$ref": "#/$defs/num" },
        "e0y": { "$ref": "#/$defs/num" },
        "e0z": { "$ref": "#/$defs/num" },
        "rho0": { "$ref": "#/$defs/num" },
        "denmod": { "$ref": "#/$defs/num_array" },
        "denk": { "$ref": "#/$defs/num_array" },
        "omegalw": { "$ref": "#/$defs/num_array" }
      }
    },
    "tmgrid_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dt": { "$ref": "#/$defs/num" },
        "dtf": { "$ref": "#/$defs/num" },
        "dr": { "$ref": "#/$defs/num" },
        "nx": { "$ref": "#/$defs/int" },
        "ny": { "$ref": "#/$defs/int" },
        "nz": { "$ref": "#/$defs/int" }
      }
    },
    "system_group": {
      "type": "object",
