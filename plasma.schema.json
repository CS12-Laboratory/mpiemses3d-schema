        "max_boundary_height": { "$ref": "#/$defs/num" },
        "emission_time_mode": { "$ref": "#/$defs/int" },
        "emission_start_step": { "$ref": "#/$defs/int" },
        "emission_end_step": { "$ref": "#/$defs/int" },
        "emission_time_sigma": { "$ref": "#/$defs/num" },
        "emission_leave_anti_particle": { "$ref": "#/$defs/bool" }
      }
    },
    "mpi_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "nodes": { "$ref": "#/$defs/int_array" }
      }
    },
    "verbose_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
