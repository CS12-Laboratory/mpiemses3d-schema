      "properties": {
        "nspec": { "$ref": "#/$defs/int" },
        "mltstp": { "$ref": "#/$defs/int" },
        "mltstpf": { "$ref": "#/$defs/int" },
        "juncan": { "$ref": "#/$defs/int" },
        "ionchg": { "$ref": "#/$defs/int" },
        "nfbnd": { "$ref": "#/$defs/int_array" },
        "npbnd": { "$ref": "#/$defs/int_value" },
        "mtd_vbnd": { "$ref": "#/$defs/int_array" },
        "boundary_conditions": { "$ref": "#/$defs/num_value" },
        "iphiref": { "$ref": "#/$defs/int_value" },
        "imask": { "$ref": "#/$defs/int_array" },
        "separate_accumulated_and_space_charge": { "$ref": "#/$defs/bool" }
      }
    },
    "intp_group": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
