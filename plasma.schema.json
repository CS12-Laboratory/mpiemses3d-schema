        "thetaz": { "$ref": "#/$defs/num" },
        "thetaxy": { "$ref": "#/$defs/num" },
        "plreloc": { "$ref": "#/$defs/num" },
        "mainprop": { "$ref": "#/$defs/num" },
        "pe_ray_cast": { "$ref": "#/$defs/bool" },
        "ray_zenith_angle_deg": { "$ref": "#/$defs/num" },
